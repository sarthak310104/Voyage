# Copy to .env at repo root before running docker compose.

# --- Postgres ---------------------------------------------------------------
POSTGRES_DB=travelcompanion
POSTGRES_USER=travelcompanion
POSTGRES_PASSWORD=changeme

# --- Java backend ------------------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRATION_MS=86400000

# --- AI service ---------------------------------------------------------------
# Supply one of these to get real AI responses. If neither is set, the AI
# service falls back to clearly-labeled mock responses so the rest of the
# app still works end-to-end without a paid key.
OPENAI_API_KEY=
GEMINI_API_KEY=your_gcp_api_key_here
AI_MODEL_PROVIDER=gemini
